---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import DailyHero from '../components/DailyHero.astro';
import DleCard from '../components/DleCard.astro';
import SiteFooter from '../components/SiteFooter.astro';
import dles from '../data/dles.json';
import type { Dle, DleCategory } from '../lib/types';
import { CATEGORY_LABELS } from '../lib/types';

const allDles = [...(dles as Dle[])].sort((a, b) =>
  a.name.localeCompare(b.name, 'pt-BR', { sensitivity: 'base' }),
);
const categories = Object.keys(CATEGORY_LABELS) as DleCategory[];
---

<Layout>
  <Header />
  <main class="container container--catalog">
    <DailyHero />

    <section class="catalog-toolbar" aria-label="Buscar e filtrar dles">
      <label class="catalog-toolbar__field" for="search">
        <span class="catalog-toolbar__label">Buscar</span>
        <input
          id="search"
          class="catalog-toolbar__search"
          type="search"
          placeholder="Nome ou descrição…"
          autocomplete="off"
          data-search-input
        />
      </label>
      <div class="catalog-toolbar__categories">
        <span class="catalog-toolbar__label" id="category-label">Categoria</span>
        <div class="filters" role="group" aria-labelledby="category-label">
          <button class="filter-chip is-active" type="button" data-filter="all">Todos</button>
          {
            categories.map((category) => (
              <button class="filter-chip" type="button" data-filter={category}>
                {CATEGORY_LABELS[category]}
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <p class="section-title">Todos os dles · <a class="section-link" href="/sugerir/">Sugerir jogo</a></p>
    <section class="dle-grid" id="dle-grid" aria-label="Catálogo de dles">
      {allDles.map((dle) => <DleCard dle={dle} />)}
    </section>
    <p class="empty-state is-hidden" id="empty-state" hidden>
      Nada por aqui. Tenta outra busca ou categoria.
    </p>
  </main>
  <SiteFooter />
</Layout>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-dle-card]'));
  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-filter]'));
  const searchInput = document.querySelector<HTMLInputElement>('[data-search-input]');
  const emptyState = document.getElementById('empty-state');

  let activeCategory = 'all';
  let query = '';

  function applyFilters() {
    let visible = 0;

    for (const card of cards) {
      const category = card.dataset.category ?? '';
      const haystack = `${card.dataset.name ?? ''} ${card.dataset.description ?? ''}`;
      const matchesCategory = activeCategory === 'all' || category === activeCategory;
      const matchesQuery = !query || haystack.includes(query);
      const show = matchesCategory && matchesQuery;
      card.classList.toggle('is-hidden', !show);
      card.toggleAttribute('hidden', !show);
      if (show) visible += 1;
    }

    if (emptyState) {
      const isEmpty = visible === 0;
      emptyState.hidden = !isEmpty;
      emptyState.classList.toggle('is-hidden', !isEmpty);
    }
  }

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => {
      activeCategory = button.dataset.filter ?? 'all';
      filterButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      applyFilters();
    });
  });

  searchInput?.addEventListener('input', () => {
    query = searchInput.value.trim().toLowerCase();
    applyFilters();
  });
</script>
