---
import { getDleInitial, resolveDleIcon } from '../lib/dle-icon';
import type { Dle } from '../lib/types';

interface Props {
  dle: Pick<Dle, 'name' | 'url' | 'icon'>;
  class?: string;
}

const { dle, class: className = 'dle-card__tile' } = Astro.props;
const { src, kind } = resolveDleIcon(dle);
const initial = getDleInitial(dle.name);
---

<div class={className} data-dle-tile aria-hidden="true">
  <span class="dle-tile__initial" data-dle-initial>{initial}</span>
  <img
    class="dle-tile__icon"
    data-dle-icon
    data-icon-kind={kind}
    src={src}
    alt=""
    width="32"
    height="32"
    loading="eager"
    decoding="async"
  />
</div>

<script>
  import { initDleTiles } from '../lib/dle-tile';

  initDleTiles();
  document.addEventListener('astro:page-load', () => initDleTiles());
</script>
