---
---

<section class="daily-hero" id="daily-hero" aria-live="polite">
  <p class="daily-hero__eyebrow" id="daily-date">Carregando sorteio…</p>
  <div class="daily-hero__body">
    <div class="daily-tile" id="daily-tile" aria-hidden="true">?</div>
    <div>
      <h1 class="daily-hero__title" id="daily-name">Sorteado do dia</h1>
      <p class="daily-hero__description" id="daily-description">
        Um dle em português sorteado para hoje. Volte amanhã para outro.
      </p>
      <a class="button-primary" id="daily-link" href="#">Jogar</a>
    </div>
  </div>
</section>

<script>
  import dles from '../data/dles.json';
  import { formatDailyDate, pickDaily } from '../lib/daily-pick';
  import type { Dle } from '../lib/types';

  const featured = (dles as Dle[]).filter((dle) => dle.featured);
  const pick = pickDaily(featured);
  const initial = pick.name.trim().charAt(0).toUpperCase() || '?';

  const hero = document.getElementById('daily-hero');
  const dateEl = document.getElementById('daily-date');
  const tileEl = document.getElementById('daily-tile');
  const nameEl = document.getElementById('daily-name');
  const descriptionEl = document.getElementById('daily-description');
  const linkEl = document.getElementById('daily-link') as HTMLAnchorElement | null;

  if (dateEl) dateEl.textContent = `${formatDailyDate()} · Sorteado do dia`;
  if (tileEl) tileEl.textContent = initial;
  if (nameEl) nameEl.textContent = pick.name;
  if (descriptionEl) descriptionEl.textContent = pick.description;
  if (linkEl) {
    linkEl.href = pick.url;
    linkEl.textContent = `Jogar ${pick.name}`;
  }
  hero?.classList.add('is-ready');
</script>
