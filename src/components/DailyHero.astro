---
import dles from '../data/dles.json';
import { formatDailyDate, pickDaily } from '../lib/daily-pick';
import DleTile from './DleTile.astro';
import type { Dle } from '../lib/types';

const featured = (dles as Dle[]).filter((dle) => dle.featured);
const pick = pickDaily(featured);
const dailyDate = formatDailyDate();
---

<section class="daily-hero is-ready" id="daily-hero" aria-live="polite">
  <p class="daily-hero__eyebrow">{dailyDate} · Sorteado do dia</p>
  <div class="daily-hero__body">
    <DleTile dle={pick} class="daily-tile" />
    <div class="daily-hero__copy">
      <h2 class="daily-hero__title">{pick.name}</h2>
      <p class="daily-hero__description">{pick.description}</p>
    </div>
    <a class="button-primary daily-hero__cta" href={pick.url} rel="noopener noreferrer">
      Jogar {pick.name}
    </a>
  </div>
</section>
